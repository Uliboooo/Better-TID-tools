{
  "manifest_version": 3,
  "name": "Better-TID-tools",
  "version": "0.3",
  "description": "AAA出席画面のEnter送信とportal.tid.ac.jpログインへの自動リダイレクトを提供します。",

  "content_scripts": [
    {
      "matches": ["https://aaaportal.tid.ac.jp/aa_web/portal/mt0010.aspx"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://portal.tid.ac.jp/*"],
      "js": ["portal-login.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
